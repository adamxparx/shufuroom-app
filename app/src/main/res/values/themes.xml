<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ShufuRoomApp" parent="Theme.MaterialComponents.Light.NoActionBar">

        <item name="android:colorBackground">@color/brand_cream</item>

        <item name="colorSurface">@color/brand_white</item>

        <item name="colorPrimary">@color/brand_pink</item>
        <item name="colorOnPrimary">@color/brand_white</item> <item name="colorOnBackground">@color/brand_burgundy</item>
        <item name="colorOnSurface">@color/brand_burgundy</item>

        <item name="toolbarStyle">@style/Widget.Shufuroom.Toolbar</item>

        <item name="bottomNavigationStyle">@style/Widget.Shufuroom.BottomNav</item>
    </style>

    <style name="Widget.Shufuroom.Toolbar" parent="Widget.MaterialComponents.Toolbar.Surface">
        <item name="android:background">@color/brand_white</item>
        <item name="titleTextColor">@color/brand_burgundy</item>
        <item name="navigationIconTint">@color/brand_pink</item> </style>

    <style name="Widget.Shufuroom.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/brand_white</item>
        <item name="itemIconTint">@color/nav_item_colors</item>
        <item name="itemTextColor">@color/nav_item_colors</item>
    </style>
</resources>